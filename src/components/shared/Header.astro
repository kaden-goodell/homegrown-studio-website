---
import { siteConfig } from '@config/site.config'

interface NavItem {
  label: string
  href: string
}

let navItems: NavItem[]

if (siteConfig.nav && siteConfig.nav.length > 0) {
  navItems = siteConfig.nav
} else {
  navItems = [
    { label: 'Home', href: '/' },
    { label: 'About', href: '/about' },
  ]
  if (siteConfig.features.workshops) {
    navItems.push({ label: 'Workshops', href: '/workshops' })
  }
  if (siteConfig.features.parties.enabled) {
    navItems.push({ label: 'Book a Party', href: '/book' })
  }
  if (siteConfig.features.gallery) {
    navItems.push({ label: 'Gallery', href: '/gallery' })
  }
}

const currentPath = Astro.url.pathname
---

<header class="sticky top-0 z-50 bg-[var(--color-background)]/80 backdrop-blur-md border-b border-[var(--color-primary)]/10">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-3 no-underline">
      <img
        src={siteConfig.logo}
        alt={`${siteConfig.name} logo`}
        class="h-8 w-auto"
        onerror="this.style.display='none'"
      />
      <span class="font-heading text-lg font-semibold text-[var(--color-text)]">
        {siteConfig.name}
      </span>
    </a>

    {/* Desktop nav */}
    <ul class="hidden md:flex items-center gap-8 list-none m-0 p-0">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'text-sm font-medium no-underline transition-colors duration-200',
              currentPath === item.href
                ? 'text-[var(--color-primary)]'
                : 'text-[var(--color-muted)] hover:text-[var(--color-primary)]',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    {/* Mobile hamburger — CSS-only */}
    <div class="md:hidden">
      <input type="checkbox" id="mobile-menu-toggle" class="peer hidden" />
      <label
        for="mobile-menu-toggle"
        class="relative flex flex-col justify-center items-center w-8 h-8 cursor-pointer gap-1.5"
        aria-label="Toggle menu"
      >
        <span class="hamburger-line block w-5 h-0.5 bg-[var(--color-text)] rounded transition-all duration-300 origin-center peer-checked:translate-y-[4px] peer-checked:rotate-45"></span>
        <span class="hamburger-line block w-5 h-0.5 bg-[var(--color-text)] rounded transition-all duration-300 peer-checked:opacity-0"></span>
        <span class="hamburger-line block w-5 h-0.5 bg-[var(--color-text)] rounded transition-all duration-300 origin-center peer-checked:-translate-y-[4px] peer-checked:-rotate-45"></span>
      </label>

      <ul class="mobile-nav hidden peer-checked:flex flex-col absolute top-16 left-0 right-0 bg-[var(--color-background)] border-b border-[var(--color-primary)]/10 shadow-lg list-none m-0 p-4 gap-1">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'block px-4 py-3 rounded-lg text-sm font-medium no-underline transition-colors duration-200',
                currentPath === item.href
                  ? 'text-[var(--color-primary)] bg-[var(--color-primary)]/5'
                  : 'text-[var(--color-muted)] hover:text-[var(--color-primary)] hover:bg-[var(--color-primary)]/5',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<style>
  /* CSS-only hamburger animation via sibling selector */
  #mobile-menu-toggle:checked ~ label .hamburger-line:nth-child(1) {
    transform: translateY(4px) rotate(45deg);
  }
  #mobile-menu-toggle:checked ~ label .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  #mobile-menu-toggle:checked ~ label .hamburger-line:nth-child(3) {
    transform: translateY(-4px) rotate(-45deg);
  }
  #mobile-menu-toggle:checked ~ .mobile-nav {
    display: flex;
  }
</style>
