---
import { siteConfig } from '@config/site.config'

interface NavItem {
  label: string
  href: string
}

let navItems: NavItem[]

if (siteConfig.nav && siteConfig.nav.length > 0) {
  navItems = siteConfig.nav
} else {
  navItems = [
    { label: 'Home', href: '/' },
    { label: 'About', href: '/about' },
  ]
  if (siteConfig.features.workshops) {
    navItems.push({ label: 'Workshops', href: '/workshops' })
  }
  if (siteConfig.features.parties.enabled) {
    navItems.push({ label: 'Book a Party', href: '/book' })
  }
  if (siteConfig.features.gallery) {
    navItems.push({ label: 'Gallery', href: '/gallery' })
  }
}

const currentYear = new Date().getFullYear()
const { street, city, state, zip } = siteConfig.address
---

<footer class="mt-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <!-- Top: Brand + Nav inline -->
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-12 mb-16">
      <div class="max-w-sm">
        <h3 class="font-heading text-2xl font-bold mb-3" style="color: var(--color-dark);">
          {siteConfig.name}
        </h3>
        <p class="text-sm leading-relaxed" style="color: var(--color-muted);">
          {siteConfig.tagline}
        </p>
      </div>

      <nav class="flex flex-wrap gap-x-8 gap-y-3">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="text-sm no-underline transition-colors duration-300"
            style="color: var(--color-muted);"
          >
            {item.label}
          </a>
        ))}
      </nav>
    </div>

    <!-- Contact row -->
    <div class="flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-8 text-sm" style="color: var(--color-muted);">
      <a
        href={`mailto:${siteConfig.contactEmail}`}
        class="no-underline transition-colors duration-300"
        style="color: var(--color-muted);"
      >
        {siteConfig.contactEmail}
      </a>
      <span class="hidden sm:inline" style="color: var(--color-secondary);">|</span>
      <a
        href={`tel:${siteConfig.contactPhone.replace(/[^+\d]/g, '')}`}
        class="no-underline transition-colors duration-300"
        style="color: var(--color-muted);"
      >
        {siteConfig.contactPhone}
      </a>
      <span class="hidden sm:inline" style="color: var(--color-secondary);">|</span>
      <span>{street}, {city}, {state} {zip}</span>
    </div>

    <!-- Divider + copyright -->
    <div class="mt-16 pt-8" style="border-top: 1px solid var(--color-secondary);">
      <p class="text-xs" style="color: var(--color-muted);">
        &copy; {currentYear} {siteConfig.name}
      </p>
    </div>
  </div>
</footer>
