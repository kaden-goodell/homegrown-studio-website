---
import { siteConfig } from '@config/site.config'

interface NavItem {
  label: string
  href: string
}

let navItems: NavItem[]

if (siteConfig.nav && siteConfig.nav.length > 0) {
  navItems = siteConfig.nav
} else {
  navItems = [
    { label: 'Home', href: '/' },
    { label: 'About', href: '/about' },
  ]
  if (siteConfig.features.workshops) {
    navItems.push({ label: 'Workshops', href: '/workshops' })
  }
  if (siteConfig.features.parties.enabled) {
    navItems.push({ label: 'Book a Party', href: '/book' })
  }
  if (siteConfig.features.gallery) {
    navItems.push({ label: 'Gallery', href: '/gallery' })
  }
}

const currentYear = new Date().getFullYear()
const { street, city, state, zip } = siteConfig.address
---

<footer class="site-footer">
  <div class="footer-inner">
    <!-- Thin divider -->
    <div class="footer-divider"></div>

    <!-- Main footer content -->
    <div class="footer-content">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo-link">
          <span class="footer-name">{siteConfig.name}</span>
        </a>
      </div>

      <!-- Nav links -->
      <nav class="footer-nav">
        {navItems.map((item) => (
          <a href={item.href} class="footer-link">{item.label}</a>
        ))}
      </nav>

      <!-- Contact -->
      <div class="footer-contact">
        <a href={`mailto:${siteConfig.contactEmail}`} class="footer-link">
          {siteConfig.contactEmail}
        </a>
        <a href={`tel:${siteConfig.contactPhone.replace(/[^+\d]/g, '')}`} class="footer-link">
          {siteConfig.contactPhone}
        </a>
        <span class="footer-address">{street}, {city}, {state} {zip}</span>
      </div>
    </div>

    <!-- Copyright -->
    <p class="footer-copyright">
      &copy; {currentYear} {siteConfig.name}
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 6rem;
    padding: 0 1.5rem;
  }

  .footer-inner {
    max-width: 72rem;
    margin: 0 auto;
  }

  .footer-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(150, 112, 91, 0.15) 20%,
      rgba(150, 112, 91, 0.15) 80%,
      transparent
    );
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    padding: 3rem 0 2rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .footer-content {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
      text-align: left;
    }
  }

  /* Brand */
  .footer-logo-link {
    text-decoration: none;
    transition: opacity 0.3s ease;
  }
  .footer-logo-link:hover {
    opacity: 0.6;
    text-decoration: none;
  }

  .footer-name {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-dark);
  }

  /* Nav */
  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .footer-nav {
      gap: 2rem;
    }
  }

  .footer-link {
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .footer-link:hover {
    color: var(--color-dark);
    text-decoration: none;
  }

  /* Contact */
  .footer-contact {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  @media (min-width: 768px) {
    .footer-contact {
      align-items: flex-end;
    }
  }

  .footer-address {
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    color: var(--color-muted);
  }

  /* Copyright */
  .footer-copyright {
    text-align: center;
    font-size: 0.6875rem;
    letter-spacing: 0.04em;
    color: rgba(150, 112, 91, 0.35);
    padding-bottom: 2.5rem;
  }
</style>
