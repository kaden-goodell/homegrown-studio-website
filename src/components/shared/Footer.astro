---
import { siteConfig } from '@config/site.config'

interface NavItem {
  label: string
  href: string
}

let navItems: NavItem[]

if (siteConfig.nav && siteConfig.nav.length > 0) {
  navItems = siteConfig.nav
} else {
  navItems = [
    { label: 'Home', href: '/' },
    { label: 'About', href: '/about' },
  ]
  if (siteConfig.features.workshops) {
    navItems.push({ label: 'Workshops', href: '/workshops' })
  }
  if (siteConfig.features.parties.enabled) {
    navItems.push({ label: 'Book a Party', href: '/book' })
  }
  if (siteConfig.features.gallery) {
    navItems.push({ label: 'Gallery', href: '/gallery' })
  }
}

const currentYear = new Date().getFullYear()
const { street, city, state, zip } = siteConfig.address
---

<footer class="bg-[var(--color-text)]/5 border-t border-[var(--color-primary)]/10 mt-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

      {/* Column 1: Brand */}
      <div>
        <h3 class="font-heading text-xl font-semibold text-[var(--color-text)] mb-3">
          {siteConfig.name}
        </h3>
        <p class="text-[var(--color-muted)] text-sm leading-relaxed">
          {siteConfig.tagline}
        </p>
        {siteConfig.features.newsletter && (
          <p class="text-[var(--color-muted)] text-sm mt-4 italic">
            Sign up for our newsletter to stay in the loop.
          </p>
        )}
      </div>

      {/* Column 2: Quick Links */}
      <div>
        <h4 class="font-heading text-sm font-semibold text-[var(--color-text)] uppercase tracking-wider mb-4">
          Quick Links
        </h4>
        <ul class="list-none m-0 p-0 space-y-2">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-[var(--color-muted)] hover:text-[var(--color-primary)] text-sm no-underline transition-colors duration-200"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Column 3: Contact */}
      <div>
        <h4 class="font-heading text-sm font-semibold text-[var(--color-text)] uppercase tracking-wider mb-4">
          Get in Touch
        </h4>
        <ul class="list-none m-0 p-0 space-y-3 text-sm text-[var(--color-muted)]">
          <li>
            <a
              href={`mailto:${siteConfig.contactEmail}`}
              class="text-[var(--color-muted)] hover:text-[var(--color-primary)] no-underline transition-colors duration-200"
            >
              {siteConfig.contactEmail}
            </a>
          </li>
          <li>
            <a
              href={`tel:${siteConfig.contactPhone.replace(/[^+\d]/g, '')}`}
              class="text-[var(--color-muted)] hover:text-[var(--color-primary)] no-underline transition-colors duration-200"
            >
              {siteConfig.contactPhone}
            </a>
          </li>
          <li class="leading-relaxed">
            {street}<br />
            {city}, {state} {zip}
          </li>
        </ul>
      </div>

    </div>
  </div>

  {/* Bottom bar */}
  <div class="border-t border-[var(--color-primary)]/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <p class="text-center text-xs text-[var(--color-muted)]">
        &copy; {currentYear} {siteConfig.name}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
