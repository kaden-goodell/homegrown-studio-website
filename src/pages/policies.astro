---
export const prerender = true

import Layout from '@layouts/StaticLayout.astro'
import { policySections } from '@config/policy-content'
---

<Layout
  title="Booking & Cancellation Policy"
  description="Homegrown Studio booking terms — cancellation windows, rescheduling, refunds, and no-show policy for parties and workshops."
>
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-28">
    {/* Deliberately NO fade-in on this page: checkout links deep-link to
        #parties/#workshops, and the scroll-reveal observer races the anchor
        jump, landing visitors on hidden content. Terms stay always-visible. */}
    <div class="glass-strong rounded-2xl px-8 py-12 sm:px-12 text-center mb-14">
      <p class="uppercase tracking-[0.2em] text-xs font-semibold mb-3" style="color: var(--color-accent);">
        The Fine Print, Unfineprinted
      </p>
      <h1 class="text-4xl md:text-5xl font-heading font-bold" style="color: var(--color-dark);">
        Booking & Cancellation Policy
      </h1>
      <p class="text-base mt-5 max-w-xl mx-auto" style="color: var(--color-muted); line-height: 1.7;">
        Plans change — here’s exactly what happens when they do. No gotchas, no
        “contact us for details”: every window and every outcome, in plain words.
      </p>
    </div>

    {policySections.map((section) => (
      <article id={section.id} class="mb-12 scroll-mt-28">
        <div class="glass rounded-2xl px-8 py-10 sm:px-10">
          <h2 class="text-2xl md:text-3xl font-heading font-bold mb-3" style="color: var(--color-dark);">
            {section.title}
          </h2>
          {section.intro && (
            <p class="mb-6 text-[0.9375rem]" style="color: var(--color-muted); line-height: 1.7;">
              {section.intro}
            </p>
          )}
          <dl class="space-y-6">
            {section.rules.map((rule) => (
              <div>
                <dt class="font-semibold text-base mb-1" style="color: var(--color-dark);">
                  {rule.heading}
                </dt>
                <dd class="text-[0.9375rem]" style="color: var(--color-text); line-height: 1.75;">
                  {rule.body}
                </dd>
              </div>
            ))}
          </dl>
        </div>
      </article>
    ))}

    <p class="text-center text-sm mt-4" style="color: var(--color-muted);">
      This policy applies to all bookings made on this site. It’s referenced at
      checkout and agreed to when you book.
    </p>
  </section>
</Layout>
