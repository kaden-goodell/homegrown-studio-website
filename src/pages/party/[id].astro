---
export const prerender = false

import Layout from '@layouts/Layout.astro'
import PartyDashboard from '@components/party/PartyDashboard'

const { id } = Astro.params
const key = Astro.url.searchParams.get('key') ?? ''
---

<Layout title="Your Party" description="Manage your Homegrown Studio party and see who's RSVP'd.">
  <section class="max-w-2xl mx-auto px-4 sm:px-6 py-24">
    <PartyDashboard client:load bookingId={id ?? ''} hostKey={key} />
  </section>
</Layout>
