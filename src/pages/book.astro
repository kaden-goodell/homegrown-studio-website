---
export const prerender = false

import Layout from '@layouts/Layout.astro'
import PartyLanding from '@components/party/PartyLanding'
---

<Layout title="Book a Party">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-28">
    <div class="text-center mb-16 fade-in">
      <p class="uppercase tracking-[0.2em] text-xs font-semibold mb-3" style="color: var(--color-accent);">Private Events</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-bold" style="color: var(--color-dark);">Book a Party</h1>
      <p class="text-lg mt-4 max-w-xl mx-auto" style="color: var(--color-muted);">
        Pick your craft and reserve the whole studio for your group. A $200 studio fee
        holds your date — crafts are paid per person at the studio.
      </p>
    </div>
    <PartyLanding client:load />
  </section>
</Layout>
