---
export const prerender = false

import Layout from '@layouts/Layout.astro'
import PartyLanding from '@components/party/PartyLanding'
import RecentPartyBanner from '@components/party/RecentPartyBanner'
import PartyFaq from '@components/party/PartyFaq.astro'
import { partyContent } from '@config/party-content'
import { siteConfig } from '@config/site.config'

const { hero, deposit } = partyContent
const kitsLive = siteConfig.features.kits.enabled
---

<Layout title="Book a Party">
  <RecentPartyBanner client:load />
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-28">
    <div class="text-center mb-16 fade-in">
      <p class="uppercase tracking-[0.2em] text-xs font-semibold mb-3" style="color: var(--color-accent);">
        {hero.eyebrow}
      </p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-bold" style="color: var(--color-dark);">
        {hero.headline}
      </h1>
      <p class="mt-4 text-sm font-medium tracking-wide" style="color: var(--color-primary);">
        {hero.occasions}
      </p>
      {hero.heroImage && (
        <img
          src={hero.heroImage}
          alt={hero.heroImageAlt}
          class="mt-8 mx-auto rounded-2xl w-full max-w-3xl object-cover"
          style="aspect-ratio: 21 / 9; box-shadow: 0 24px 60px rgba(150, 112, 91, 0.18);"
        />
      )}
      <p class="text-lg mt-6 max-w-xl mx-auto" style="color: var(--color-muted);">
        {hero.subline}
      </p>
      <div class="mt-5 flex flex-wrap justify-center gap-2">
        {hero.valueTrio.map((item) => (
          <span
            class="inline-flex items-center gap-1.5 rounded-full px-4 py-1.5 text-xs font-semibold"
            style="background: rgba(150, 112, 91, 0.08); border: 1px solid rgba(150, 112, 91, 0.14); color: var(--color-dark);"
          >
            {item}
          </span>
        ))}
      </div>
      <p class="mt-6 text-sm font-semibold" style="color: var(--color-dark);">
        {deposit.holdLine}
      </p>
      <a
        href="#open-dates"
        class="inline-block mt-5 rounded-xl px-8 py-3.5 text-sm font-semibold text-white transition-shadow"
        style="background: linear-gradient(135deg, var(--color-primary), var(--color-accent)); box-shadow: 0 4px 15px rgba(150, 112, 91, 0.25);"
      >
        See open dates
      </a>
    </div>
    <PartyLanding client:load />
    <div class="glass rounded-2xl px-8 py-10 sm:px-12 text-center mt-16 fade-in">
      <p class="uppercase tracking-[0.2em] text-xs font-semibold mb-3" style="color: var(--color-accent);">
        {kitsLive ? 'New' : 'Coming Soon'}
      </p>
      <h2 class="text-2xl sm:text-3xl font-heading font-bold mb-3" style="color: var(--color-dark);">Take-Home Party Kits</h2>
      <p class="text-base max-w-xl mx-auto leading-relaxed" style="color: var(--color-muted);">
        {kitsLive
          ? 'Want the party without booking the studio? A themed craft kit for your crew, styled table and all — pick up Thursday, host at home.'
          : 'Want the party without booking the studio? We’re boxing up themed craft kits — gold, silver, rainbow, and more — so you can host at home. Join the newsletter and you’ll be the first to know.'}
      </p>
      {kitsLive && (
        <a
          href="/kits"
          class="inline-block mt-6 rounded-xl px-8 py-3.5 text-sm font-semibold text-white no-underline"
          style="background: linear-gradient(135deg, var(--color-primary), var(--color-accent)); box-shadow: 0 4px 15px rgba(150, 112, 91, 0.25);"
        >
          Build your kit
        </a>
      )}
    </div>
    <PartyFaq />
  </section>
</Layout>
