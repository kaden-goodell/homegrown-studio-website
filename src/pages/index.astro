---
export const prerender = true

import Layout from '@layouts/StaticLayout.astro'
import { siteConfig } from '@config/site.config'
import Newsletter from '@components/shared/Newsletter'

const features = siteConfig.features

const offerings = [
  features.parties.enabled && {
    title: 'Private Parties',
    description: 'Celebrate birthdays and special moments with a custom crafting party your guests will never forget.',
    href: '/book',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.871c1.355 0 2.697.056 4.024.166C17.155 8.51 18 9.473 18 10.608v2.513M15 8.25v-1.5m-6 1.5v-1.5m12 9.75-1.5.75a3.354 3.354 0 0 1-3 0 3.354 3.354 0 0 0-3 0 3.354 3.354 0 0 1-3 0 3.354 3.354 0 0 0-3 0 3.354 3.354 0 0 1-3 0L3 16.5m15-3.379a48.474 48.474 0 0 0-6-.371c-2.032 0-4.034.126-6 .371m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.169c0 .621-.504 1.125-1.125 1.125H4.125A1.125 1.125 0 0 1 3 20.625v-5.17c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 0 1 6 13.12M12.265 3.11a.375.375 0 1 1-.53.53.375.375 0 0 1 .53-.53Z" /></svg>`,
    primary: true,
  },
  features.workshops && {
    title: 'Creative Workshops',
    description: 'Hands-on crafting sessions for all skill levels.',
    href: '/workshops',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42" /></svg>`,
    primary: false,
  },
  features.gallery && {
    title: 'Our Gallery',
    description: 'Browse creations from our studio.',
    href: '/gallery',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" /></svg>`,
    primary: false,
  },
].filter(Boolean) as { title: string; description: string; href: string; icon: string; primary: boolean }[]

const ctaText = features.parties.enabled ? 'Book a Party' : 'Browse Workshops'
const ctaHref = features.parties.enabled ? '/book' : '/workshops'

const testimonials = siteConfig.testimonials?.items ?? []
---

<Layout title="Home">
  <!-- Hero — full viewport, text pops on frosted glass -->
  <section class="relative min-h-screen flex flex-col items-center justify-center px-4">
    <div class="relative z-10 max-w-3xl mx-auto text-center">
      <!-- Glass panel behind hero text -->
      <div class="glass-strong rounded-3xl px-8 py-14 sm:px-14 sm:py-20">
        <h1 class="fade-in font-heading font-bold mb-6 text-5xl sm:text-6xl lg:text-7xl" style="color: var(--color-dark); letter-spacing: -0.01em;">
          {siteConfig.tagline}
        </h1>
        <p class="fade-in text-lg sm:text-xl leading-relaxed mb-10 mx-auto" style="color: var(--color-muted); max-width: 34ch;">
          Handcrafted workshops, birthday parties, and creative experiences for all ages
        </p>
        <a
          href={ctaHref}
          class="fade-in cta-glow inline-block rounded-full px-12 py-4 text-white font-semibold text-lg no-underline"
          style="background: linear-gradient(135deg, var(--color-primary), var(--color-accent)); box-shadow: 0 8px 30px rgba(150, 112, 91, 0.3);"
        >
          {ctaText}
        </a>
      </div>
    </div>
    <!-- Scroll chevron -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 scroll-hint">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5" style="color: var(--color-secondary);">
        <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
      </svg>
    </div>
  </section>

  <!-- Offerings — glass cards, flowing into page -->
  <section class="py-24 sm:py-32 px-4 -mt-20 relative z-10">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16 fade-in">
        <p class="uppercase tracking-[0.2em] text-xs font-semibold mb-3" style="color: var(--color-accent);">Explore</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold" style="color: var(--color-dark);">What We Offer</h2>
      </div>

      <div class="grid gap-5 grid-cols-1 md:grid-cols-3">
        {offerings.map((item) => (
          <a
            href={item.href}
            class:list={[
              'group block rounded-2xl overflow-hidden hover-card glass no-underline',
              item.primary ? 'md:col-span-2 md:row-span-2' : '',
            ]}
          >
            <div class:list={['p-8', item.primary ? 'sm:p-12' : '']}>
              <div class="mb-6 inline-flex items-center justify-center w-14 h-14 rounded-xl transition-all duration-300 group-hover:scale-110" style="color: var(--color-primary); background: rgba(150, 112, 91, 0.08);" set:html={item.icon} />
              <h3 class:list={[
                'font-heading font-bold mb-3 transition-colors duration-300',
                item.primary ? 'text-2xl md:text-3xl' : 'text-xl',
              ]} style="color: var(--color-dark);">
                {item.title}
              </h3>
              <p class:list={[
                'leading-relaxed',
                item.primary ? 'text-base' : 'text-sm',
              ]} style="color: var(--color-muted);">
                {item.description}
              </p>
              <div class="mt-6 flex items-center gap-2 text-sm font-medium transition-all duration-300 group-hover:gap-3" style="color: var(--color-primary);">
                <span>Explore</span>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials — large editorial quotes on glass -->
  {testimonials.length > 0 && (
    <section class="py-24 sm:py-32 px-4">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-16 fade-in">
          <p class="uppercase tracking-[0.2em] text-xs font-semibold mb-3" style="color: var(--color-accent);">Testimonials</p>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold" style="color: var(--color-dark);">
            {siteConfig.testimonials?.heading || 'What Our Guests Say'}
          </h2>
        </div>

        <div class="testimonial-scroll flex gap-6 overflow-x-auto pb-6 snap-x snap-mandatory -mx-4 px-4">
          {testimonials.map((t) => (
            <div class="min-w-full sm:min-w-[75%] flex-shrink-0 snap-center">
              <blockquote class="glass rounded-2xl p-10 sm:p-14 hover-card">
                <p class="font-heading italic text-2xl sm:text-3xl lg:text-4xl leading-snug mb-10" style="color: var(--color-dark);">
                  &ldquo;{t.quote}&rdquo;
                </p>
                <footer class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold text-sm" style="background: linear-gradient(135deg, var(--color-primary), var(--color-accent));">
                    {t.name.charAt(0)}
                  </div>
                  <div>
                    <span class="block font-semibold text-sm" style="color: var(--color-dark);">{t.name}</span>
                    <span class="block text-xs" style="color: var(--color-muted);">{t.detail}</span>
                  </div>
                </footer>
              </blockquote>
            </div>
          ))}
        </div>

        {testimonials.length > 1 && (
          <div class="flex justify-center gap-2.5 mt-8">
            {testimonials.map((_, i) => (
              <div
                class="w-2 h-2 rounded-full transition-all duration-300"
                style={`background-color: ${i === 0 ? 'var(--color-primary)' : 'rgba(150, 112, 91, 0.2)'};`}
              />
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Newsletter -->
  {features.newsletter && (
    <section class="py-24 sm:py-32 px-4">
      <div class="glass rounded-2xl max-w-2xl mx-auto px-8 py-14 sm:px-14">
        <Newsletter client:visible />
      </div>
    </section>
  )}
</Layout>

<style>
  .testimonial-scroll {
    scrollbar-width: none;
  }
  .testimonial-scroll::-webkit-scrollbar {
    display: none;
  }
</style>
