---
export const prerender = true

import Layout from '@layouts/StaticLayout.astro'
import { siteConfig } from '@config/site.config'
import Newsletter from '@components/shared/Newsletter'

const features = siteConfig.features

const offerings = [
  features.parties.enabled && {
    title: 'Private Parties',
    description: 'Celebrate birthdays and special moments with a custom crafting party your guests will never forget.',
    href: '/book',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.871c1.355 0 2.697.056 4.024.166C17.155 8.51 18 9.473 18 10.608v2.513M15 8.25v-1.5m-6 1.5v-1.5m12 9.75-1.5.75a3.354 3.354 0 0 1-3 0 3.354 3.354 0 0 0-3 0 3.354 3.354 0 0 1-3 0 3.354 3.354 0 0 0-3 0 3.354 3.354 0 0 1-3 0L3 16.5m15-3.379a48.474 48.474 0 0 0-6-.371c-2.032 0-4.034.126-6 .371m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.169c0 .621-.504 1.125-1.125 1.125H4.125A1.125 1.125 0 0 1 3 20.625v-5.17c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 0 1 6 13.12M12.265 3.11a.375.375 0 1 1-.53.53.375.375 0 0 1 .53-.53Z" /></svg>`,
    primary: true,
  },
  features.workshops && {
    title: 'Creative Workshops',
    description: 'Hands-on crafting sessions for all skill levels. Discover something new and leave with a handmade treasure.',
    href: '/workshops',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42" /></svg>`,
    primary: false,
  },
  features.gallery && {
    title: 'Our Gallery',
    description: 'Browse photos of past workshops, parties, and the beautiful creations made in our studio.',
    href: '/gallery',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" /></svg>`,
    primary: false,
  },
].filter(Boolean) as { title: string; description: string; href: string; icon: string; primary: boolean }[]

const ctaText = features.parties.enabled ? 'Book a Party' : 'Browse Workshops'
const ctaHref = features.parties.enabled ? '/book' : '/workshops'

const testimonials = siteConfig.testimonials?.items ?? []
---

<Layout title="Home">
  <!-- Hero -->
  <section class="relative min-h-screen flex flex-col items-center justify-center px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="fade-in font-heading font-bold tracking-wide mb-6 text-5xl sm:text-6xl lg:text-7xl" style="color: var(--color-text); letter-spacing: 0.02em;">
        {siteConfig.tagline}
      </h1>
      <p class="fade-in text-lg sm:text-xl leading-relaxed mb-10 mx-auto" style="color: var(--color-muted); max-width: 32ch;">
        Handcrafted workshops, birthday parties, and creative experiences for all ages
      </p>
      <a
        href={ctaHref}
        class="fade-in inline-block rounded-full px-10 py-4 text-white font-semibold text-lg transition hover:-translate-y-0.5"
        style="background-color: var(--color-primary); box-shadow: 0 4px 20px rgba(150, 112, 91, 0.25);"
      >
        {ctaText}
      </a>
    </div>
    <!-- Scroll chevron -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 scroll-hint">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6" style="color: var(--color-muted);">
        <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
      </svg>
    </div>
  </section>

  <!-- Offerings (asymmetric) -->
  <section class="py-20 sm:py-28 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="mb-14">
        <div class="w-12 h-0.5 mb-4" style="background-color: var(--color-secondary);"></div>
        <h2 class="text-3xl sm:text-4xl font-heading font-bold" style="color: var(--color-text);">What We Offer</h2>
      </div>

      <div class="grid gap-6 grid-cols-1 md:grid-cols-3">
        {offerings.map((item) => (
          <a
            href={item.href}
            class:list={[
              'group block rounded-xl p-8 border transition hover:-translate-y-1 hover:shadow-lg no-underline',
              item.primary ? 'md:col-span-2 md:row-span-2 p-10' : '',
            ]}
            style="background-color: #f5f0ea; border-color: rgba(196, 168, 130, 0.3);"
          >
            <div class="mb-5" style="color: var(--color-primary);" set:html={item.icon} />
            <h3 class:list={[
              'font-heading font-semibold mb-3 transition-colors group-hover:text-[var(--color-primary)]',
              item.primary ? 'text-2xl md:text-3xl' : 'text-xl',
            ]} style="color: var(--color-text);">
              {item.title}
            </h3>
            <p class:list={[
              'leading-relaxed',
              item.primary ? 'text-base' : 'text-sm',
            ]} style="color: var(--color-muted);">
              {item.description}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials (horizontal scroll) -->
  {testimonials.length > 0 && (
    <section class="py-20 sm:py-28 px-4">
      <div class="max-w-6xl mx-auto">
        <div class="mb-14">
          <div class="w-12 h-0.5 mb-4" style="background-color: var(--color-secondary);"></div>
          <h2 class="text-3xl sm:text-4xl font-heading font-bold" style="color: var(--color-text);">
            {siteConfig.testimonials?.heading || 'What Our Guests Say'}
          </h2>
        </div>

        <div class="testimonial-scroll flex gap-8 overflow-x-auto pb-6 snap-x snap-mandatory -mx-4 px-4">
          {testimonials.map((t) => (
            <div class="min-w-full sm:min-w-[80%] flex-shrink-0 snap-start">
              <blockquote class="rounded-xl p-10 sm:p-12" style="background-color: #f5f0ea; border: 1px solid rgba(196, 168, 130, 0.2);">
                <p class="font-heading italic text-2xl sm:text-3xl leading-relaxed mb-8" style="color: var(--color-text);">
                  &ldquo;{t.quote}&rdquo;
                </p>
                <footer class="text-right">
                  <cite class="not-italic">
                    <span class="block font-semibold text-sm" style="color: var(--color-text);">{t.name}</span>
                    <span class="block text-xs mt-1" style="color: var(--color-muted);">{t.detail}</span>
                  </cite>
                </footer>
              </blockquote>
            </div>
          ))}
        </div>

        <!-- Dot indicators -->
        {testimonials.length > 1 && (
          <div class="flex justify-center gap-2 mt-6">
            {testimonials.map((_, i) => (
              <div
                class="w-2 h-2 rounded-full transition-colors"
                style={`background-color: ${i === 0 ? 'var(--color-primary)' : 'var(--color-secondary)'};`}
              />
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Newsletter (dark section) -->
  {features.newsletter && (
    <section class="py-20 sm:py-28 px-4" style="background-color: var(--color-dark);">
      <Newsletter client:visible variant="dark" />
    </section>
  )}
</Layout>

<style>
  .testimonial-scroll {
    scrollbar-width: thin;
    scrollbar-color: var(--color-secondary) transparent;
  }
  .testimonial-scroll::-webkit-scrollbar {
    height: 6px;
  }
  .testimonial-scroll::-webkit-scrollbar-track {
    background: transparent;
  }
  .testimonial-scroll::-webkit-scrollbar-thumb {
    background: var(--color-secondary);
    border-radius: 3px;
  }
</style>
