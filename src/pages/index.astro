---
import Layout from '@layouts/Layout.astro'
import { siteConfig } from '@config/site.config'
---

<Layout title="Home">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
    <h1 class="text-4xl font-heading font-bold mb-4">{siteConfig.name}</h1>
    <p class="text-xl text-[var(--color-muted)]">{siteConfig.tagline}</p>
  </section>
</Layout>
