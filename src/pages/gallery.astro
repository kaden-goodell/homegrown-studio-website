---
export const prerender = true

import Layout from '@layouts/Layout.astro'
import { siteConfig } from '@config/site.config'
import Lightbox from '@components/shared/Lightbox'

const galleryItems = [
  { id: '1', title: 'Candle Making Workshop', caption: 'Guests creating custom soy candles', color: '#c4b5fd' },
  { id: '2', title: 'Birthday Party Setup', caption: 'A beautiful craft party for 12 kids', color: '#fbbf24' },
  { id: '3', title: 'Pottery Class', caption: 'Wheel-thrown pottery basics', color: '#a78bfa' },
  { id: '4', title: 'Watercolor Session', caption: 'Painting landscapes with watercolors', color: '#93c5fd' },
  { id: '5', title: 'Corporate Team Building', caption: 'Team crafting experience for 30', color: '#86efac' },
  { id: '6', title: 'Soap Making', caption: 'Natural ingredient artisan soaps', color: '#fca5a5' },
  { id: '7', title: 'Studio Space', caption: 'Our bright and airy workshop space', color: '#d8b4fe' },
  { id: '8', title: 'Kids Art Class', caption: 'Young artists exploring creativity', color: '#fdba74' },
]

const aspectRatios = ['3/4', '1/1', '4/3', '3/4', '4/3', '1/1', '3/4', '4/3']
---

<Layout title="Gallery" description="A glimpse into our creative space at Homegrown Craft Studio">
  {siteConfig.features.gallery ? (
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="text-center mb-16">
        <h1 class="text-4xl sm:text-5xl font-heading font-bold mb-4">Gallery</h1>
        <p class="text-lg text-[var(--color-muted)] max-w-xl mx-auto">
          A glimpse into our creative space
        </p>
      </div>

      <div class="gallery-grid">
        {galleryItems.map((item, i) => (
          <div
            class="gallery-item fade-in hover-lift cursor-pointer group rounded-lg overflow-hidden"
            onclick={`window.dispatchEvent(new CustomEvent('open-lightbox', { detail: { index: ${i} } }))`}
            role="button"
            tabindex="0"
            aria-label={`View ${item.title}`}
          >
            <div
              class="gallery-image"
              style={`background-color: ${item.color}; aspect-ratio: ${aspectRatios[i]};`}
            >
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-300" />
            </div>
            <div class="p-4">
              <h3 class="font-heading font-semibold text-sm">{item.title}</h3>
              <p class="text-xs text-[var(--color-muted)] mt-1">{item.caption}</p>
            </div>
          </div>
        ))}
      </div>

      <Lightbox client:visible items={galleryItems} />
    </section>
  ) : (
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
      <h1 class="text-4xl font-heading font-bold mb-4">Gallery</h1>
      <p class="text-lg text-[var(--color-muted)]">Gallery is not available at this time.</p>
    </section>
  )}
</Layout>

<style>
  .gallery-grid {
    columns: 1;
    column-gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .gallery-grid {
      columns: 2;
    }
  }

  @media (min-width: 1024px) {
    .gallery-grid {
      columns: 3;
    }
  }

  .gallery-item {
    break-inside: avoid;
    margin-bottom: 1.5rem;
    background: white;
  }

  .gallery-image {
    position: relative;
    width: 100%;
  }
</style>

<script>
  function initGallery() {
    const items = document.querySelectorAll('.gallery-item')
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible')
            observer.unobserve(entry.target)
          }
        })
      },
      { threshold: 0.1 }
    )
    items.forEach((item) => observer.observe(item))

    items.forEach((item) => {
      item.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
          e.preventDefault()
          ;(item as HTMLElement).click()
        }
      })
    })
  }

  initGallery()
  document.addEventListener('astro:after-swap', initGallery)
</script>
