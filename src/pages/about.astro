---
export const prerender = true

import Layout from '@layouts/StaticLayout.astro'
import { siteConfig } from '@config/site.config'
import { getCollection, render } from 'astro:content'

const aboutEntries = await getCollection('about')
aboutEntries.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))

const rendered = await Promise.all(
  aboutEntries.map(async (entry) => {
    const { Content } = await render(entry)
    return { entry, Content }
  })
)
---

<Layout title="About">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-28">
    <!-- Page header on glass -->
    <div class="glass-strong rounded-2xl px-8 py-12 sm:px-12 text-center mb-20 fade-in">
      <p class="uppercase tracking-[0.2em] text-xs font-semibold mb-3" style="color: var(--color-accent);">Our Story</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold" style="color: var(--color-dark);">
        About {siteConfig.name}
      </h1>
    </div>

    {rendered.map(({ entry, Content }) => (
      <article class="mb-16 fade-in">
        <div class="glass rounded-2xl px-8 py-10 sm:px-12 sm:py-12">
          <h2 class="text-2xl md:text-3xl font-heading font-bold mb-6" style="color: var(--color-dark);">
            {entry.data.title}
          </h2>
          <div class="prose prose-lg max-w-none leading-relaxed [&>p]:mb-6" style="color: var(--color-text); line-height: 1.9;">
            <Content />
          </div>
        </div>
      </article>
    ))}
  </section>
</Layout>
