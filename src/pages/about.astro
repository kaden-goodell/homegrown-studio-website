---
export const prerender = true

import Layout from '@layouts/StaticLayout.astro'
import { siteConfig } from '@config/site.config'
import { getCollection, render } from 'astro:content'

const aboutEntries = await getCollection('about')
aboutEntries.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))

const rendered = await Promise.all(
  aboutEntries.map(async (entry) => {
    const { Content } = await render(entry)
    return { entry, Content }
  })
)
---

<Layout title="About">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-28">
    <h1 class="text-4xl md:text-5xl font-heading font-bold text-center mb-4 fade-in" style="color: var(--color-text);">
      About {siteConfig.name}
    </h1>
    <div class="w-16 h-0.5 mx-auto mt-6 mb-20" style="background-color: var(--color-secondary);"></div>

    {rendered.map(({ entry, Content }) => (
      <article class="mb-20 fade-in">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-8 h-0.5 flex-shrink-0" style="background-color: var(--color-secondary);"></div>
          <h2 class="text-2xl md:text-3xl font-heading font-semibold" style="color: var(--color-primary);">
            {entry.data.title}
          </h2>
        </div>
        <div class="prose prose-lg max-w-none leading-relaxed [&>p]:mb-6" style="color: var(--color-text); line-height: 1.9;">
          <Content />
        </div>
      </article>
    ))}
  </section>
</Layout>
