---
export const prerender = false

import Layout from '@layouts/Layout.astro'
import WhatsOnCalendar from '@components/calendar/WhatsOnCalendar'

// Events are fetched per-month, client-side, from /api/calendar.json?month=YYYY-MM
// (one month at a time keeps each Square availability query under the 32-day cap).
---

<Layout title="What's On" description="Workshops, open studio walk-in hours, and events at Homegrown Studio">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-28">
    <div class="text-center mb-16 fade-in">
      <p class="uppercase tracking-[0.2em] text-xs font-semibold mb-3" style="color: var(--color-accent);">This Month</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-bold" style="color: var(--color-dark);">What's On at the Studio</h1>
      <p class="text-lg mt-4 max-w-xl mx-auto" style="color: var(--color-muted);">
        Workshops, open studio walk-in hours, and bookable parties — all in one place
      </p>
    </div>
    <WhatsOnCalendar client:load />
  </section>
</Layout>
