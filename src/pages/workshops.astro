---
export const prerender = false

import Layout from '@layouts/Layout.astro'
import WorkshopExplorer from '@components/workshops/WorkshopExplorer'

// Workshops are fetched client-side (via /api/workshops.json) so this page renders
// instantly instead of blocking navigation on the (sometimes slow) Square Classes API.
---

<Layout title="Workshops">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-28">
    <div class="text-center mb-16 fade-in">
      <p class="uppercase tracking-[0.2em] text-xs font-semibold mb-3" style="color: var(--color-accent);">Upcoming</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-bold" style="color: var(--color-dark);">Workshops</h1>
      <p class="text-lg mt-4 max-w-xl mx-auto" style="color: var(--color-muted);">
        Guided crafting sessions, everything included — grab a seat before they fill up. Want the full picture? <a href="/calendar" class="underline" style="color: var(--color-primary);">See what's on</a>.
      </p>
    </div>
    <WorkshopExplorer client:load />

    <!-- Adult nights positioning band (HOM-161) — evergreen copy, no invented listings. -->
    <div class="max-w-2xl mx-auto mt-20 text-center fade-in">
      <div class="glass rounded-2xl px-8 py-10 sm:px-12">
        <p class="uppercase tracking-[0.2em] text-xs font-semibold mb-3" style="color: var(--color-accent);">
          Nights Out, But Make It Craft
        </p>
        <h2 class="text-2xl md:text-3xl font-heading font-bold mb-4" style="color: var(--color-dark);">
          Workshops for grown-ups
        </h2>
        <p class="text-base" style="color: var(--color-muted); line-height: 1.8;">
          Girls' nights, date nights, or just a better Thursday — think needlepoint,
          tufting, candle pouring, and seasonal makes, with everything included and
          no experience needed. New sessions are added all the time, so check back
          or <a href="/calendar" class="underline" style="color: var(--color-primary);">watch the calendar</a>.
          And yes — wine nights are planned once our beer &amp; wine license is approved.
        </p>
      </div>
    </div>
  </section>
</Layout>
