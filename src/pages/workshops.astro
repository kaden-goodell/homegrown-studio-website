---
export const prerender = false

import Layout from '@layouts/Layout.astro'
import WorkshopExplorer from '@components/workshops/WorkshopExplorer'

// Workshops are fetched client-side (via /api/workshops.json) so this page renders
// instantly instead of blocking navigation on the (sometimes slow) Square Classes API.
---

<Layout title="Workshops">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-28">
    <div class="text-center mb-16 fade-in">
      <p class="uppercase tracking-[0.2em] text-xs font-semibold mb-3" style="color: var(--color-accent);">Upcoming</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-bold" style="color: var(--color-dark);">Workshops</h1>
      <p class="text-lg mt-4 max-w-xl mx-auto" style="color: var(--color-muted);">
        Drop-in crafting sessions and creative workshops for all skill levels
      </p>
    </div>
    <WorkshopExplorer client:load />
  </section>
</Layout>
