---
export const prerender = false

import Layout from '@layouts/Layout.astro'
import { siteConfig } from '@config/site.config'
import { getClassInstances } from '@providers/square/classes'
import WorkshopExplorer from '@components/workshops/WorkshopExplorer'
import type { WorkshopData } from '@components/workshops/WorkshopExplorer'

const locationId = siteConfig.providers.booking.config.locationId || ''

let workshops: WorkshopData[] = []

if (locationId) {
  try {
    const classes = await getClassInstances(locationId)

    workshops = classes
      .filter((c) => c.availableCapacity > 0)
      .map((c) => ({
        id: c.id,
        name: c.name,
        description: c.description,
        category: 'workshop',
        date: c.startAt.split('T')[0],
        startTime: c.startAt,
        endTime: new Date(new Date(c.startAt).getTime() + c.durationMinutes * 60_000).toISOString(),
        duration: c.durationMinutes,
        price: c.price * 100, // WorkshopData expects cents
        currency: c.currency,
        remainingSeats: c.availableCapacity,
        classScheduleId: c.classScheduleId,
        classScheduleInstanceId: c.id,
        teamMemberId: c.teamMemberId,
      }))
  } catch {
    // Classes API may not be available (e.g. sandbox)
  }
}
---

<Layout title="Workshops">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-28">
    <div class="text-center mb-16 fade-in">
      <p class="uppercase tracking-[0.2em] text-xs font-semibold mb-3" style="color: var(--color-accent);">Upcoming</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-bold" style="color: var(--color-dark);">Workshops</h1>
      <p class="text-lg mt-4 max-w-xl mx-auto" style="color: var(--color-muted);">
        Drop-in crafting sessions and creative workshops for all skill levels
      </p>
    </div>
    <WorkshopExplorer client:load workshops={workshops} />
  </section>
</Layout>
